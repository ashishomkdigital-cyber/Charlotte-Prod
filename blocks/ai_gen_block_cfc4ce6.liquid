{% doc %}
  @prompt
    create a block where it tales the liquid code ., make the background transparent, make the background transparent and give options to set the baground color
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-liquid-code-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-liquid-code-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  .ai-liquid-code-empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-size: 14px;
    font-style: italic;
    background-color: #f9f9f9;
    border: 1px dashed #ddd;
    border-radius: {{ block.settings.border_radius }}px;
  }
{% endstyle %}

<div
  class="ai-liquid-code-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.liquid_code != blank %}
    <div class="ai-liquid-code-content-{{ ai_gen_id }}">
      {{ block.settings.liquid_code }}
    </div>
  {% else %}
    <div class="ai-liquid-code-empty-{{ ai_gen_id }}">
      Next, add your custom Liquid code in the block settings
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom liquid code",
  "tag": null,
  "settings": [
    {
      "type": "liquid",
      "id": "liquid_code",
      "label": "Liquid code"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Left",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Right",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom liquid code"
    }
  ]
}
{% endschema %}
