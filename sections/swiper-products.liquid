<style>
  .swipe-shop {
    min-height: 100vh;
    padding: 20px 14px 32px;
    background:
      linear-gradient(rgba(40,18,5,.4), rgba(20,8,2,.75)),
      url("{{section.settings.background_image | image_url }}");
    background-size: cover;
    color: #fff;
    overflow: hidden;
    font-family: serif;
  }

  .swipe-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .swipe-header h2 {
    font-size: 34px;
    font-weight: 400;
    margin: 0;
  }

  .toggle {
    width: 46px;
    height: 28px;
    background: rgba(255,255,255,.45);
    border-radius: 50px;
    position: relative;
  }

  .toggle:after {
    content: "";
    position: absolute;
    right: 2px;
    top: 2px;
    width: 24px;
    height: 24px;
    background: #5a2d0b;
    border-radius: 50%;
  }

  .swipe-stack {
    position: relative;
    height: 620px;
    max-width: 460px;
    margin: 50px auto 20px;
  }

  .swipe-card {
    position: absolute;
    inset: 0;
    padding: 14px;
    background: linear-gradient(135deg, #b98c35, #fff4b0, #8a5c14);
    border-radius: 8px;
    box-shadow: 0 18px 45px rgba(0,0,0,.55);
    touch-action: none;
    transition: transform .35s ease, opacity .35s ease;
    cursor: grab;
  }

  .swipe-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 6px solid #1d1207;
  }

  .swipe-info {
    position: absolute;
    bottom: 70px;
    left: 42px;
    right: 42px;
    display: flex;
    justify-content: center;
    gap: 12px;
    font-size: 22px;
    text-shadow: 0 2px 10px #000;
  }

  .swipe-info h3 {
    margin: 0;
    font-weight: 400;
  }

  .swipe-card.swipe-left {
    transform: translateX(-130%) rotate(-18deg);
    opacity: 0;
  }

  .swipe-card.swipe-right {
    transform: translateX(130%) rotate(18deg) scale(.9);
    opacity: 0;
  }

  .swipe-card.adding {
    animation: addPulse .45s ease;
  }

  @keyframes addPulse {
    0% { box-shadow: 0 0 0 rgba(255,255,255,0); }
    50% { box-shadow: 0 0 45px rgba(255,255,255,.9); }
    100% { box-shadow: 0 18px 45px rgba(0,0,0,.55); }
  }

  .swipe-add-btn {
    width: 100%;
    max-width: 500px;
    margin: 80px auto 0;
    display: block;
    border: 0;
    border-radius: 24px;
    padding: 24px;
    background: #4b2508;
    color: #ddd;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 4px;
  }

  .swipe-dots {
    display: flex;
    justify-content: center;
    gap: 14px;
  }

  .swipe-dots span {
    width: 12px;
    height: 12px;
    background: rgba(255,255,255,.55);
    border-radius: 50%;
  }

  .swipe-dots span.active {
    width: 34px;
    border-radius: 20px;
    background: #6b390d;
  }
</style>
<style>
  .open-swipe-layout {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 9999;
    padding: 14px 20px;
    border: 1px solid rgba(197, 159, 78, 0.4);
    border-radius: 999px;
    background: rgba(19, 10, 6, 0.9);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .open-swipe-layout:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.5);
  }

  body.swipe-layout-open .open-swipe-layout {
    opacity: 0;
    pointer-events: none;
  }

  .swipe-overlay {
    position: fixed;
    inset: 0;
    z-index: 999999;
    display: none;
    background: #120803;
    overflow-y: auto;
  }

  .swipe-overlay.active {
    display: block;
  }

  .close-swipe-layout {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 1000000;
    width: 52px;
    height: 52px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    background: rgba(12, 8, 5, 0.85);
    color: #fff;
    font-size: 32px;
    line-height: 48px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0,0,0,0.45);
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
  }

  .close-swipe-layout:hover {
    transform: scale(1.05);
    background: rgba(12, 8, 5, 0.95);
    border-color: #b98c35;
  }

  body.swipe-layout-open {
    overflow: hidden !important;
    height: 100vh;
  }

  /* Flyer dynamic thumbnail animation */
  .shopify-swiper-flyer {
    position: absolute;
    z-index: 9999999;
    width: 80px;
    height: 100px;
    border: 3px solid #b98c35;
    object-fit: cover;
    pointer-events: none;
    box-shadow: 0 8px 20px rgba(0,0,0,0.5);
    animation: swiperFlyToCart 0.85s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes swiperFlyToCart {
    0% {
      transform: translate3d(var(--start-x), var(--start-y), 0) scale(1) rotate(0deg);
      opacity: 1;
    }
    30% {
      transform: translate3d(calc(var(--start-x) - 30px), calc(var(--start-y) - 20px), 0) scale(1.05) rotate(-10deg);
      opacity: 1;
    }
    100% {
      transform: translate3d(var(--end-x), var(--end-y), 0) scale(0.08) rotate(35deg);
      opacity: 0.1;
    }
  }

  .cart-badge-bounce {
    animation: cartBounce 0.5s ease-in-out;
  }

  @keyframes cartBounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }

  @media screen and (max-width: 749px) {
    .open-swipe-layout {
      right: 16px;
      bottom: 16px;
      padding: 12px 16px;
      font-size: 12px;
    }
    .close-swipe-layout {
      right: 16px;
      bottom: 16px;
      width: 46px;
      height: 46px;
      font-size: 28px;
    }
  }
</style>
<button class="open-swipe-layout" type="button">
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px; vertical-align: middle;">
    <path d="M7 4h10"></path>
    <path d="M5 8h14"></path>
    <path d="M3 12h18"></path>
    <path d="M5 16h14"></path>
    <path d="M7 20h10"></path>
  </svg>
  Swipe Shop
</button>

<div class="swipe-overlay" id="SwipeOverlay-{{ section.id }}">
  <button class="close-swipe-layout" type="button" aria-label="Close swipe shop">×</button>

  <section class="swipe-shop">
    <div class="swipe-header">
    <span>‹ Back</span>
    <h2>{{ section.settings.title }}</h2>
    <span class="toggle"></span>
  </div>

  <div class="swipe-stack" id="SwipeStack-{{ section.id }}">
    {% for product in section.settings.collection.products limit: section.settings.limit %}
      <div class="swipe-card" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
        <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title }}">
        <div class="swipe-info">
          <h3>{{ product.title }}</h3>
          <span>{{ product.price | money }}</span>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="swipe-dots"></div>

  <button class="swipe-add-btn">Swipe to Add</button>
  </section>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const stack = document.querySelector('#SwipeStack-{{ section.id }}');
    if (!stack) return;

    let cards = [...stack.querySelectorAll('.swipe-card')];
    const dots = document.querySelector('.swipe-dots');

    function updateStack() {
      // Exclude cards that are currently swiping away from the active stack layout
      cards = [...stack.querySelectorAll('.swipe-card:not(.swiping-away)')];

      cards.forEach((card, index) => {
        card.style.transition = 'transform 0.35s ease, opacity 0.35s ease';
        card.style.zIndex = cards.length - index;
        card.style.transform = `scale(${1 - index * 0.035}) translateY(${index * 8}px)`;
        card.style.opacity = index > 3 ? '0' : '1';
      });

      dots.innerHTML = '';
      cards.slice(0, 5).forEach((_, i) => {
        const dot = document.createElement('span');
        if (i === 0) dot.classList.add('active');
        dots.appendChild(dot);
      });
    }

    function triggerCartFlight(cardElement) {
      const img = cardElement.querySelector('img');
      if (!img) return;

      // Query theme cart button
      let cartBtn = document.querySelector('.header__icon--cart, .cart-icon, [href="/cart"], .cart-link, .header__icon.button');
      
      // Fallback: if not found, use close button
      if (!cartBtn) {
        cartBtn = document.querySelector('.close-swipe-layout') || cardElement;
      }

      const startRect = img.getBoundingClientRect();
      const endRect = cartBtn.getBoundingClientRect();

      const flyer = document.createElement('img');
      flyer.src = img.src;
      flyer.className = 'shopify-swiper-flyer';

      flyer.style.left = '0px';
      flyer.style.top = '0px';

      const bodyScrollLeft = window.pageXOffset || document.documentElement.scrollLeft;
      const bodyScrollTop = window.pageYOffset || document.documentElement.scrollTop;

      const startX = startRect.left + bodyScrollLeft;
      const startY = startRect.top + bodyScrollTop;
      const endX = endRect.left + (endRect.width / 2) - (startRect.width / 2) + bodyScrollLeft;
      const endY = endRect.top + (endRect.height / 2) - (startRect.height / 2) + bodyScrollTop;

      flyer.style.setProperty('--start-x', `${startX}px`);
      flyer.style.setProperty('--start-y', `${startY}px`);
      flyer.style.setProperty('--end-x', `${endX}px`);
      flyer.style.setProperty('--end-y', `${endY}px`);

      document.body.appendChild(flyer);

      setTimeout(() => {
        flyer.remove();
        cartBtn.classList.add('cart-badge-bounce');
        setTimeout(() => cartBtn.classList.remove('cart-badge-bounce'), 500);
      }, 850);
    }

    async function addToCart(card) {
      const variantId = card.dataset.variantId;
      if (!variantId) return;
      card.classList.add('adding');

      const cartDrawer = document.querySelector('cart-drawer');
      const formData = new FormData();
      formData.append('id', variantId);
      formData.append('quantity', 1);

      // Request updated sections from Shopify to refresh drawer and count bubbles
      if (cartDrawer && typeof cartDrawer.getSectionsToRender === 'function') {
        formData.append('sections', cartDrawer.getSectionsToRender().map((section) => section.id).join(','));
        formData.append('sections_url', window.location.pathname);
        if (typeof cartDrawer.setActiveElement === 'function') {
          cartDrawer.setActiveElement(document.activeElement);
        }
      }

      try {
        const cartAddUrl = (window.routes && window.routes.cart_add_url) ? window.routes.cart_add_url : '/cart/add';
        const response = await fetch(cartAddUrl, {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/javascript'
          },
          body: formData,
        });

        const data = await response.json();

        if (response.ok) {
          // Trigger theme pubsub system if present (updates header cart icon bubbles)
          if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
            publish(PUB_SUB_EVENTS.cartUpdate, {
              source: 'swiper-products',
              productVariantId: Number(variantId),
              cartData: data,
            });
          }

          // Render updated cart drawer contents
          if (cartDrawer && typeof cartDrawer.renderContents === 'function') {
            cartDrawer.renderContents(data);
          } else {
            document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));
          }
        } else {
          console.error('Error adding variant to cart:', data.description || data.message);
        }
      } catch (error) {
        console.error('Error in addToCart:', error);
      }
    }

    function removeCard(card, direction) {
      // Mark card as swiped immediately so the next card is instantly interactive
      card.classList.add('swiping-away');
      card.classList.add(direction === 'right' ? 'swipe-right' : 'swipe-left');
      card.style.transition = 'transform 0.35s ease, opacity 0.35s ease';

      // Set explicit inline transform and opacity to animate off-screen cleanly
      if (direction === 'right') {
        card.style.transform = 'translateX(130%) rotate(18deg) scale(0.9)';
        triggerCartFlight(card);
      } else {
        card.style.transform = 'translateX(-130%) rotate(-18deg) scale(0.9)';
      }
      card.style.opacity = '0';

      // Update remaining cards stack immediately for a smooth, concurrent animation
      updateStack();

      setTimeout(() => {
        card.remove();
      }, 350);
    }

    function initSwipe(card) {
      let startX = 0;
      let currentX = 0;
      let dragging = false;

      card.addEventListener('pointerdown', (e) => {
        if (card.classList.contains('swiping-away')) return;

        dragging = true;
        startX = e.clientX;
        card.setPointerCapture(e.pointerId);
        card.style.transition = 'none';
      });

      card.addEventListener('pointermove', (e) => {
        // Only allow dragging the topmost active card
        if (!dragging || card !== stack.querySelector('.swipe-card:not(.swiping-away)')) return;

        currentX = e.clientX - startX;
        const rotate = currentX / 16;

        card.style.transform = `translateX(${currentX}px) rotate(${rotate}deg)`;
      });

      card.addEventListener('pointerup', (e) => {
        if (!dragging) return;

        dragging = false;
        card.style.transition = '';

        if (currentX > 110) {
          addToCart(card); // Trigger in background
          removeCard(card, 'right');
        } else if (currentX < -110) {
          removeCard(card, 'left');
        } else {
          updateStack();
        }

        currentX = 0;
      });
    }

    // Connect swipe actions to the CTA button if present
    const addBtn = document.querySelector('.swipe-add-btn');
    if (addBtn) {
      addBtn.addEventListener('click', () => {
        const topCard = stack.querySelector('.swipe-card:not(.swiping-away)');
        if (topCard) {
          addToCart(topCard);
          removeCard(topCard, 'right');
        }
      });
    }

    cards.forEach(initSwipe);
    updateStack();
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.querySelector('#SwipeOverlay-{{ section.id }}');
    const openBtn = document.querySelector('.open-swipe-layout');
    const closeBtn = overlay?.querySelector('.close-swipe-layout');

    if (!overlay || !openBtn || !closeBtn) return;

    openBtn.addEventListener('click', () => {
      overlay.classList.add('active');
      document.body.classList.add('swipe-layout-open');
    });

    closeBtn.addEventListener('click', () => {
      overlay.classList.remove('active');
      document.body.classList.remove('swipe-layout-open');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        overlay.classList.remove('active');
        document.body.classList.remove('swipe-layout-open');
      }
    });
  });
</script>

{% schema %}
{
  "name": "Tinder Swipe Products",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Choose Background"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "CHARLOTTE"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Product collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products limit",
      "min": 3,
      "max": 20,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Tinder Swipe Products"
    }
  ]
}
{% endschema %}
