<section class="three-image-columns">
  <div class="three-image-columns__grid">

    {%- for i in (1..3) -%}
      {%- assign image_key = 'image_' | append: i -%}
      {%- assign link_key  = 'link_'  | append: i -%}

      <div class="three-image-columns__item">
        <a href="{{ section.settings[link_key] }}" class="three-image-columns__link">
          {%- if section.settings[image_key] != blank -%}
            {{
              section.settings[image_key]
              | image_url: width: 800
              | image_tag: loading: 'lazy', class: 'three-image-columns__img'
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'three-image-columns__img placeholder' }}
          {%- endif -%}
        </a>
      </div>

    {%- endfor -%}

  </div>
</section>

<style>
  .three-image-columns{
    background-color:#E8D5B7;
    padding-bottom:90px;
  }
  .three-image-columns__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ section.settings.gap }}px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  .three-image-columns__link {
    display: block;
    overflow: hidden;
  }
  .three-image-columns__img {
    width: 350px;
    height: 440px;
    display: block;
    transition: transform 0.3s ease;
  }
  {% comment %} .three-image-columns__link:hover .three-image-columns__img {
    transform: scale(1.03);
  } {% endcomment %}
  @media (max-width: 768px) {
    .three-image-columns__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Three Image Columns",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image_1", "label": "Image 1" },
    { "type": "url",          "id": "link_1",  "label": "Link 1" },
    { "type": "image_picker", "id": "image_2", "label": "Image 2" },
    { "type": "url",          "id": "link_2",  "label": "Link 2" },
    { "type": "image_picker", "id": "image_3", "label": "Image 3" },
    { "type": "url",          "id": "link_3",  "label": "Link 3" },
    { "type": "range", "id": "gap",       "label": "Gap (px)",       "min": 0,   "max": 60,   "step": 4,  "default": 16 },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 800, "max": 1600, "step": 40, "default": 1200 }
  ],
  "presets": [
    { "name": "Three Image Columns" }
  ]
}
{% endschema %}